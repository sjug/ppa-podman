#!/usr/bin/make -f

export DH_VERBOSE = 1

%:
	dh $@

override_dh_auto_build:
	# Nothing to build - config files only

override_dh_auto_install:
	install -D -m 0644 storage.conf \
		debian/containers-common/etc/containers/storage.conf
	install -D -m 0644 registries.conf \
		debian/containers-common/etc/containers/registries.conf
	install -D -m 0644 policy.json \
		debian/containers-common/etc/containers/policy.json
	install -D -m 0644 containers.conf \
		debian/containers-common/etc/containers/containers.conf
	install -D -m 0644 default.yaml \
		debian/containers-common/etc/containers/registries.d/default.yaml
	install -D -m 0644 seccomp.json \
		debian/containers-common/usr/share/containers/seccomp.json
	install -D -m 0644 shortnames.conf \
		debian/containers-common/etc/containers/registries.conf.d/000-shortnames.conf

override_dh_auto_test:
	# Nothing to test
