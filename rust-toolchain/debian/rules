#!/usr/bin/make -f

export DH_VERBOSE = 1
RUSTDIR = /usr/lib/rust-1.86
INSTALL_ROOT = $(CURDIR)/debian/rust-toolchain-1.86$(RUSTDIR)

%:
	dh $@

override_dh_auto_build:
	# Nothing to compile — repackaging official binaries

override_dh_auto_install:
	mkdir -p $(INSTALL_ROOT)
	tar xf rust-1.86.0-aarch64.tar.xz
	cd rust-1.86.0-aarch64-unknown-linux-gnu && \
		./install.sh --destdir=$(CURDIR)/debian/rust-toolchain-1.86 --prefix=$(RUSTDIR) --disable-ldconfig
	# Create convenience symlinks in the bin dir
	mkdir -p $(CURDIR)/debian/rust-toolchain-1.86/usr/bin
	ln -sf ../lib/rust-1.86/bin/rustc $(CURDIR)/debian/rust-toolchain-1.86/usr/bin/rustc-1.86
	ln -sf ../lib/rust-1.86/bin/cargo $(CURDIR)/debian/rust-toolchain-1.86/usr/bin/cargo-1.86

override_dh_auto_test:
	# No tests

override_dh_dwz:
	# Pre-built binaries have incompatible debug info

override_dh_strip:
	# Do not strip pre-built binaries

override_dh_shlibdeps:
	dh_shlibdeps --dpkg-shlibdeps-params=--ignore-missing-info
